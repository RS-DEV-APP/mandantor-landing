---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
</head>
<body class="app-body">
  <slot />
  <footer class="app-footer">
    <div class="app-footer-inner">
      <span>Mandantor</span>
      <span class="dot">·</span>
      <a href="/impressum">Impressum</a>
      <span class="dot">·</span>
      <a href="/datenschutz">Datenschutz</a>
    </div>
  </footer>
</body>
</html>

<style is:global>
  .app-body {
    background: var(--paper);
    min-height: 100vh;
  }
  .app-shell {
    max-width: 880px;
    margin: 0 auto;
    padding: 64px var(--gutter);
  }
  .app-card {
    border: 1px solid var(--rule-strong);
    background: var(--paper);
    padding: 40px;
  }
  .app-input {
    width: 100%;
    font-family: var(--sans);
    font-size: 16px;
    padding: 14px 16px;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 2px;
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
  }
  .app-input:focus { border-color: var(--ink); }
  .app-label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 20px;
  }
  .app-label-text {
    font-family: var(--mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .app-error {
    color: #b23a3a;
    font-size: 14px;
    margin-top: 12px;
  }
  .app-success {
    color: var(--ink);
    font-size: 16px;
    margin-top: 16px;
    line-height: 1.6;
  }
  .app-footer {
    border-top: 1px solid var(--rule);
    margin-top: 80px;
    padding: 24px var(--gutter);
  }
  .app-footer-inner {
    max-width: 880px;
    margin: 0 auto;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .app-footer a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .app-footer a:hover { color: var(--ink); }
  .app-footer .dot { opacity: 0.4; }

  /* ── Mobile-Polish (Anwalt-App) ─────────────────────────────────── */
  @media (max-width: 640px) {
    .app-shell { padding: 32px 16px; }
    .app-card { padding: 20px 16px; }

    /* iOS auto-zoom auf input deaktivieren */
    .app-input { font-size: 16px !important; padding: 12px 14px; }

    /* Two-column-Inline-Grids stack vertikal — wir nutzen Attribute-Selektoren,
       weil sehr viele Pages die Grids inline mit style="..." setzen. */
    [style*="grid-template-columns: 1fr 1fr"],
    [style*="grid-template-columns: 2fr 1fr"],
    [style*="grid-template-columns: 1fr 2fr"],
    [style*="grid-template-columns: 200px 1fr"],
    [style*="grid-template-columns: 240px 1fr"],
    [style*="grid-template-columns: 120px 1fr"],
    [style*="grid-template-columns: 60px 1fr auto"] {
      grid-template-columns: 1fr !important;
      gap: 12px !important;
    }

    /* Header-Layouts mit nav buttons brechen um */
    header[style*="justify-content: space-between"] {
      flex-direction: column !important;
      align-items: flex-start !important;
      gap: 16px !important;
    }
    header[style*="justify-content: space-between"] > div:last-child {
      width: 100%;
    }

    /* CTA-Rows (Onboarding, Account, Settings) brechen um */
    [class*="cta-row"], [class*="cta_row"] {
      flex-direction: column-reverse !important;
      align-items: stretch !important;
      gap: 12px !important;
    }
    [class*="cta-row"] > * { width: 100%; text-align: center; }
    [class*="cta-row"] > * > * { width: auto; }

    /* H1 in Headers etwas kleiner */
    h1.serif { font-size: 28px !important; line-height: 1.15 !important; }
    h2.serif { font-size: 19px !important; }

    /* Tab-Toggle (Aktiv/Archiv) kompakter */
    .tab { padding: 6px 10px !important; font-size: 11px !important; }

    /* Stat-Card Grid (Account-Übersicht) */
    [style*="grid-template-columns: repeat(auto-fit"] {
      grid-template-columns: 1fr 1fr !important;
    }

    /* Tables / file rows scrollen horizontal nicht — innerlich stacken */
    .file-row {
      flex-wrap: wrap;
      gap: 8px;
    }

    /* Step-Nav Onboarding / Mandant-Wizard horizontal scrollbar */
    .onb-steps, .step-nav ol {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      flex-wrap: nowrap !important;
    }
    .onb-steps::-webkit-scrollbar, .step-nav ol::-webkit-scrollbar { display: none; }
  }
</style>
