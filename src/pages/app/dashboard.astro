---
import AppLayout from '../../layouts/AppLayout.astro';
import { findKanzleiById } from '../../lib/db';
import { listAkten } from '../../lib/akten';
import { listAktenTypen } from '../../lib/akten_typ';

export const prerender = false;

const session = Astro.locals.session;
const env = Astro.locals.runtime.env;

if (!session) {
  return Astro.redirect('/app/login', 302);
}

const kanzlei = await findKanzleiById(env.DB, session.kanzlei_id);
if (!kanzlei) {
  return Astro.redirect('/app/login', 302);
}

const url = new URL(Astro.request.url);
const showArchived = url.searchParams.get('archived_view') === '1';
const archivedNotice = url.searchParams.get('archived');
const queryRaw = url.searchParams.get('q') ?? '';
const query = queryRaw.trim();
const akten = await listAkten(env.DB, kanzlei.id, { includeArchived: showArchived, query });
const aktenTypen = await listAktenTypen(env.DB, kanzlei.id);
const visibleAkten = showArchived
  ? akten.filter((a) => a.status === 'archived')
  : akten;

const fmtDate = (ts: number) =>
  new Date(ts * 1000).toLocaleDateString('de-DE', {
    day: '2-digit', month: '2-digit', year: 'numeric',
  });

const statusLabel = (status: string) => {
  switch (status) {
    case 'draft': return 'Wartet auf Mandant';
    case 'in_progress': return 'In Bearbeitung';
    case 'submitted': return 'Eingereicht';
    case 'archived': return 'Archiviert';
    default: return status;
  }
};

const needsKanzleiSetup =
  /^[a-zA-Z]\.[a-zA-Z]/.test(kanzlei.display_name) &&
  !kanzlei.display_name.includes(' ');
---
<AppLayout title="Dashboard — Mandantor">
  <main class="app-shell">
    <header style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 40px;">
      <div>
        <span class="marker">
          <span class="pilcrow" style="color: var(--gold);">§</span>
          <span style="font-family: var(--mono); font-size: var(--fs-mono); letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted);">Dashboard</span>
        </span>
        <h1 class="serif" style="font-size: 36px; margin: 12px 0 4px; letter-spacing: -0.015em;">
          {kanzlei.display_name}
        </h1>
        <p style="font-size: 14px; color: var(--muted);">{kanzlei.email}</p>
      </div>
      <div style="display: flex; gap: 16px; align-items: center;">
        <a href="/app/account" class="tlink" style="font-size: 14px;">Account</a>
        <a href="/app/settings" class="tlink" style="font-size: 14px;">Einstellungen</a>
        <form method="post" action="/api/auth/logout" style="margin: 0;">
          <button type="submit" class="btn btn-ghost">Abmelden</button>
        </form>
      </div>
    </header>

    <div class="app-card" style="margin-bottom: 24px;">
      <h2 class="serif" style="font-size: 22px; margin-bottom: 12px;">Neue Akte anlegen</h2>
      <p style="color: var(--ink-2); font-size: 14px; margin-bottom: 20px;">
        Sie erhalten einen Mandanten-Link, den Sie per E-Mail verschicken oder kopieren können.
      </p>
      <form method="post" action="/api/akten/create" style="display: grid; gap: 12px;">
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 12px;">
          <label class="app-label" style="margin: 0;">
            <span class="app-label-text">Aktenbezeichnung (optional)</span>
            <input type="text" name="case_label" value={url.searchParams.get('case_label') ?? ''} placeholder="z. B. Mietsache Müller" class="app-input" />
          </label>
          {aktenTypen.length > 0 && (
            <label class="app-label" style="margin: 0;">
              <span class="app-label-text">Akten-Typ</span>
              <select name="akten_typ_id" class="app-input">
                <option value="">— Standard —</option>
                {aktenTypen.map((t) => (
                  <option value={t.id} selected={url.searchParams.get('akten_typ_id') === t.id}>{t.name}</option>
                ))}
              </select>
            </label>
          )}
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
          <label class="app-label" style="margin: 0;">
            <span class="app-label-text">Mandant-E-Mail (optional)</span>
            <input type="email" name="mandant_email" value={url.searchParams.get('mandant_email') ?? ''} placeholder="mandant@beispiel.de" class="app-input" />
          </label>
          <label class="app-label" style="margin: 0;">
            <span class="app-label-text">Mandant-Name (optional)</span>
            <input type="text" name="mandant_name" value={url.searchParams.get('mandant_name') ?? ''} placeholder="Anna Beispiel" class="app-input" />
          </label>
        </div>
        {url.searchParams.get('conflict_id') && (
          <div style="padding: 12px 16px; background: #fffaf0; border: 1px solid #e6d4a3; border-left: 4px solid var(--gold); font-size: 14px;">
            <strong>Möglicher Mandanten-Konflikt</strong> — eine bestehende Akte
            <a href={`/app/akten/${url.searchParams.get('conflict_id')}`} class="tlink" style="margin: 0 4px;">{url.searchParams.get('conflict_label')}</a>
            verwendet diese Mandanten-Daten bereits. Prüfen Sie BORA-konforme Mandatsführung (§ 43a BRAO).
            <input type="hidden" name="confirm_conflict" value="1" />
            <p style="margin: 8px 0 0; font-size: 13px; color: var(--muted);">Klick „Akte anlegen" erneut, um den Konflikt zu bestätigen und die neue Akte trotzdem zu erstellen.</p>
          </div>
        )}
        <div style="display: flex; justify-content: flex-end;">
          <button type="submit" class="btn">
            <span>Akte anlegen</span>
            <span class="arrow">→</span>
          </button>
        </div>
      </form>
    </div>

    {url.searchParams.get('limit_error') && (
      <p class="app-error" style="margin: 0 0 24px 0; padding: 12px 16px; background: #fdf0f0; border: 1px solid #e6c5c5; font-size: 14px;">
        {url.searchParams.get('limit_error')}
      </p>
    )}

    {url.searchParams.get('reactivated') && (
      <p class="app-success" style="margin: 0 0 24px 0; padding: 12px 16px; background: #f0f7f0; border: 1px solid #c5e0c5; font-size: 14px;">
        ✓ Akte <strong>{url.searchParams.get('reactivated')}</strong> reaktiviert.
      </p>
    )}

    {url.searchParams.get('onboarded') === '1' && (
      <div class="app-card" style="margin-bottom: 24px; border-left: 4px solid var(--gold); background: #fffaf0;">
        <h2 class="serif" style="font-size: 18px; margin: 0 0 8px;">Willkommen — Setup abgeschlossen.</h2>
        <p style="color: var(--ink-2); font-size: 14px; margin: 0;">
          Ihre Kanzlei ist eingerichtet. Legen Sie unten Ihre erste Akte an,
          oder erkunden Sie weitere Funktionen unter <a href="/app/account" class="tlink">Account</a>.
        </p>
      </div>
    )}

    {needsKanzleiSetup && (
      <div class="app-card" style="margin-bottom: 24px; border-left: 4px solid var(--gold); background: #fffaf0;">
        <h2 class="serif" style="font-size: 18px; margin: 0 0 8px;">Kanzlei-Daten vervollständigen</h2>
        <p style="color: var(--ink-2); font-size: 14px; margin: 0 0 12px;">
          Ihre Kanzlei wird Mandant:innen aktuell als <strong>{kanzlei.display_name}</strong> angezeigt.
          Tragen Sie unter Einstellungen Ihren richtigen Kanzlei-Namen sowie Vollmacht- und Honorar-Vorlagen ein.
        </p>
        <a href="/app/settings" class="tlink" style="font-size: 14px;">Zu den Einstellungen →</a>
      </div>
    )}

    {archivedNotice && (
      <p class="app-success" style="margin: 0 0 24px 0; padding: 12px 16px; background: #f0f7f0; border: 1px solid #c5e0c5; font-size: 14px;">
        ✓ Akte <strong>{archivedNotice}</strong> archiviert.
      </p>
    )}

    <div class="app-card">
      <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16px; gap: 16px; flex-wrap: wrap;">
        <h2 class="serif" style="font-size: 22px; margin: 0;">{showArchived ? 'Archiv' : 'Akten'}</h2>
        <div style="display: flex; gap: 8px; font-size: 13px;">
          <a
            href="/app/dashboard"
            class={showArchived ? 'tab' : 'tab tab--active'}
          >Aktiv</a>
          <a
            href="/app/dashboard?archived_view=1"
            class={showArchived ? 'tab tab--active' : 'tab'}
          >Archiv</a>
        </div>
      </div>
      <form method="get" action="/app/dashboard" style="display: flex; gap: 8px; margin-bottom: 16px;">
        {showArchived && <input type="hidden" name="archived_view" value="1" />}
        <input type="search" name="q" value={query} placeholder="Akte suchen — Bezeichnung, Mandant-Name oder E-Mail" class="app-input" style="flex: 1;" />
        {query && <a href={showArchived ? '/app/dashboard?archived_view=1' : '/app/dashboard'} class="tlink" style="font-size: 13px; align-self: center;">Filter aufheben</a>}
      </form>
      {visibleAkten.length === 0 ? (
        <p style="color: var(--muted); font-size: 14px; padding: 16px 0;">
          {showArchived ? 'Keine archivierten Akten.' : 'Noch keine Akten angelegt.'}
        </p>
      ) : (
        <ul style="list-style: none; padding: 0; margin: 0;">
          {visibleAkten.map((a) => {
            const ts = a.submitted_at ?? a.created_at;
            const tsLabel = a.submitted_at ? `eingereicht ${fmtDate(ts)}` : `angelegt ${fmtDate(ts)}`;
            const retentionLabel = a.retention_marked_at ? `Lösch-Backlog (${fmtDate(a.retention_marked_at)})` : null;
            return (
              <li style="border-bottom: 1px solid var(--rule); position: relative;">
                <a href={`/app/akten/${a.id}`} class="akte-row">
                  <span class="akte-row-title">
                    {a.case_label ?? 'Ohne Bezeichnung'}
                    {a.mandant_name && <span style="color: var(--muted); font-size: 13px; margin-left: 8px;">· {a.mandant_name}</span>}
                  </span>
                  <span class={`status-badge status-${a.status}`}>{statusLabel(a.status)}</span>
                  <span class="akte-row-date">
                    {retentionLabel ? <span style="color: #b23a3a;">{retentionLabel}</span> : tsLabel}
                  </span>
                </a>
                {showArchived && (
                  <form method="post" action="/api/akten/reactivate" style="position: absolute; right: 0; top: 50%; transform: translateY(-50%); margin: 0;">
                    <input type="hidden" name="akte_id" value={a.id} />
                    <button type="submit" class="reactivate-btn">Reaktivieren</button>
                  </form>
                )}
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </main>
</AppLayout>

<style>
  .tab {
    padding: 6px 14px;
    border: 1px solid var(--rule);
    color: var(--muted);
    text-decoration: none;
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 2px;
  }
  .tab--active {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
  .akte-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 16px;
    padding: 16px 0;
    align-items: baseline;
    color: var(--ink);
    text-decoration: none;
    border: 0;
  }
  .akte-row:hover .akte-row-title { text-decoration: underline; }
  .akte-row-title { font-size: 16px; }
  .akte-row-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
  }
  .status-badge {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    white-space: nowrap;
  }
  .status-draft { background: #fef7e6; color: #8a6d1a; }
  .status-in_progress { background: #e8f0fe; color: #1a4d8a; }
  .status-submitted { background: #e6f4ea; color: #1a6d2c; }
  .status-archived { background: #f0f0f0; color: #555; }
  .reactivate-btn {
    padding: 6px 10px;
    font-family: var(--sans);
    font-size: 12px;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 2px;
    cursor: pointer;
  }
  .reactivate-btn:hover { background: #f5f3ee; }
</style>
