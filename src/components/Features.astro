---
const items = [
  {
    n: '01',
    title: 'Ein Link statt acht Anhänge.',
    body: 'Statt PDF-Vollmacht, Word-Datei für Stammdaten und einer E-Mail mit „bitte unterschrieben zurück" — schicken Sie einen Link. Mandant:innen füllen Stammdaten, bestätigen Vollmacht, Datenschutz und Honorar und laden Dokumente hoch. In einer Sitzung, am Schreibtisch oder mobil.',
    kicker: 'Onboarding',
    bullets: ['Mobile-optimiert (iOS/Android)', 'Pausieren und fortsetzen', 'Reminder bei Inaktivität'],
  },
  {
    n: '02',
    title: 'Vorlagen pro Mandatsart.',
    body: 'Mietsache, Verkehrsunfall, Familienrecht — Sie definieren pro Akten-Typ einen eigenen Vollmacht- und DSGVO-Text, eigene Honorarsätze und eine Liste erwarteter Dokumente. Beim Anlegen einer Akte wählen Sie den Typ aus — Mandant:innen sehen typ-spezifische Texte.',
    kicker: 'Vorlagen',
    bullets: ['Eigene Vollmacht- und DSGVO-Texte', 'Honorarsätze pro Mandatsart', 'Eigenes Logo und Akzentfarbe'],
  },
  {
    n: '03',
    title: 'DSGVO und BORA — eingebaut.',
    body: 'EU-Hosting bei Cloudflare (Frankfurt). Append-only Audit-Log mit Hash-Chain (§ 8 GwG, Art. 30 DSGVO). Aufbewahrungs-Automatik (§ 50 BRAO 5 Jahre). Konflikt-Check bei Akte-Anlage (§ 43a BRAO). 2-Faktor-Authentifizierung. AVV vor Pilot-Aufnahme.',
    kicker: 'Compliance',
    bullets: ['Hash-Chain-Audit-Log', '2FA + IP/UA-Audit pro Bestätigung', 'Konflikt- und Aufbewahrungs-Automatik'],
  },
  {
    n: '04',
    title: 'Übergabe in Ihre Akte.',
    body: 'Was bei Ihnen ankommt: ein strukturierter Datensatz, ein PDF-Dossier mit allen Bestätigungen und Audit-Spuren, Dokumente als ZIP, Akten-Detailseite mit Status-Workflow. Anwalt-Notizen pro Akte. Mandant kann nachträglich um Korrektur gebeten werden.',
    kicker: 'Übergabe',
    bullets: ['PDF-Akten-Export (PDF/A-nahe)', 'ZIP-Bulk-Download aller Dokumente', 'Re-Open-Schleife für Mandant'],
  },
];
---
<section id="features" class="features">
  <div class="container">
    <div class="features-marker-row">
      <span class="marker">
        <span class="pilcrow">§</span>
        <span>Was Mandantor leistet</span>
      </span>
      <span class="mono">Vier Bausteine.</span>
    </div>

    <div class="features-list">
      {items.map((item, i) => (
        <article class={`feature${i === items.length - 1 ? ' is-last' : ''}`}>
          <div class="feature-num-block">
            <span class="serif feature-num">{item.n}</span>
            <span class="mono">{item.kicker}</span>
          </div>

          <div>
            <h3 class="serif feature-title">{item.title}</h3>
          </div>

          <div class="feature-body-block">
            <p class="feature-body">{item.body}</p>
            <ul class="feature-bullets">
              {item.bullets.map((b) => (
                <li class="feature-bullet">
                  <span class="mono feature-bullet-dash">—</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features { padding: 120px 0; }
  .features-marker-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 56px;
  }
  .features-list { display: flex; flex-direction: column; }
  .feature {
    display: grid;
    grid-template-columns: 120px 1fr 1fr;
    gap: 56px;
    padding: 56px 0;
    border-top: 1px solid var(--rule);
    align-items: start;
  }
  .feature.is-last { border-bottom: 1px solid var(--rule); }
  .feature-num-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .feature-num {
    font-size: 48px;
    color: var(--gold);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .feature-title {
    font-size: 32px;
    line-height: 1.15;
    letter-spacing: -0.015em;
    max-width: 18ch;
  }
  .feature-body-block {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .feature-body {
    font-size: 16.5px;
    line-height: 1.6;
    color: var(--ink-2);
  }
  .feature-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .feature-bullet {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: 8px;
    align-items: baseline;
    font-size: 14.5px;
    color: var(--ink-2);
  }
  .feature-bullet-dash { color: var(--muted-2); }

  @media (max-width: 880px) {
    .features { padding: 64px 0; }
    .features-marker-row { flex-direction: column; gap: 8px; align-items: flex-start; margin-bottom: 32px; }
    .feature { grid-template-columns: 1fr; gap: 16px; padding: 32px 0; }
    .feature-num { font-size: 36px; }
    .feature-title { font-size: 24px; }
  }
</style>
