---
import BrandIcon from './BrandIcon.astro';
import Wordmark from './Wordmark.astro';
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="/" class="footer-brand">
          <BrandIcon size={26} />
          <Wordmark size={22} showLine={false} />
        </a>
        <p class="footer-tagline">
          Mandanten-Onboarding für deutsche Kanzleien. Hosting in Frankfurt am Main.
        </p>
      </div>

      <div class="footer-col">
        <div class="mono footer-col-title">Produkt</div>
        <ul class="footer-list">
          <li><a href="/#how" class="tlink">So funktioniert es</a></li>
          <li><a href="/#features" class="tlink">Funktionen</a></li>
          <li><a href="/preise" class="tlink">Preise</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <div class="mono footer-col-title">Konto</div>
        <ul class="footer-list">
          <li><a href="/app/login" class="tlink">Anmelden</a></li>
          <li><a href="/app/login" class="tlink">Kostenlos testen</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <div class="mono footer-col-title">Rechtliches</div>
        <ul class="footer-list">
          <li><a href="/impressum" class="tlink">Impressum</a></li>
          <li><a href="/datenschutz" class="tlink">Datenschutz</a></li>
          <li><a href="/datenschutz#avv" class="tlink">AVV (Muster)</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <div class="mono footer-col-title">Kontakt</div>
        <ul class="footer-list">
          <li><a href="mailto:hello@mandantor.de" class="tlink">hello@mandantor.de</a></li>
          <li class="footer-list-muted">Werktags · München</li>
        </ul>
      </div>
    </div>

    <hr class="rule" />
    <div class="footer-base">
      <span>© 2026 Mandantor. Pilot-Phase — alle Pilot-Konditionen vorläufig.</span>
      <span class="mono">v0.5 · Mai 2026</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rule-strong);
    padding: 56px 0 40px;
    background: var(--paper);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 36px;
    margin-bottom: 48px;
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .footer-tagline {
    font-size: 14px;
    color: var(--muted);
    max-width: 36ch;
  }
  .footer-col-title {
    margin-bottom: 14px;
  }
  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-list li {
    font-size: 14px;
    color: var(--ink-2);
  }
  .footer-list-muted { color: var(--muted); }
  .footer-base {
    display: flex;
    justify-content: space-between;
    padding-top: 24px;
    font-size: 12.5px;
    color: var(--muted);
  }

  @media (max-width: 880px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .footer-base {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
