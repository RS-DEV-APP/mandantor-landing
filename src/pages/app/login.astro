---
import AppLayout from '../../layouts/AppLayout.astro';

export const prerender = false;

const url = new URL(Astro.request.url);
const sent = url.searchParams.get('sent') === '1';
const error = url.searchParams.get('error');
---
<AppLayout title="Anmelden — Mandantor">
  <main class="app-shell">
    <div class="app-card">
      <span class="marker">
        <span class="pilcrow" style="color: var(--gold);">§</span>
        <span style="font-family: var(--mono); font-size: var(--fs-mono); letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted);">Anmeldung</span>
      </span>

      <h1 class="serif" style="font-size: 36px; margin: 16px 0 12px; letter-spacing: -0.015em;">
        Bei Mandantor anmelden.
      </h1>
      <p style="color: var(--ink-2); font-size: 16px; line-height: 1.6; max-width: 50ch;">
        Wir schicken einen einmaligen Link an Ihre Kanzlei-E-Mail-Adresse.
        Kein Passwort.
      </p>

      {sent ? (
        <div class="app-success" style="margin-top: 32px;">
          <span style="display: inline-block; font-family: var(--mono); font-size: 12px; color: var(--gold); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 12px;">
            ✓ E-Mail unterwegs
          </span>
          <h2 class="serif" style="font-size: 24px; margin: 0 0 12px; letter-spacing: -0.01em;">
            Schauen Sie ins Postfach.
          </h2>
          <p style="color: var(--ink-2); font-size: 15px; line-height: 1.6;">
            Wir haben einen einmaligen Anmeldelink an die angegebene Adresse geschickt.
            Der Link ist 15 Minuten gültig.
          </p>
          <p style="color: var(--muted); font-size: 13px; margin-top: 16px;">
            Falls keine Mail ankommt, schauen Sie zuerst im Spam-Ordner nach.
          </p>
          <p style="margin-top: 24px;">
            <a href="/app/login" class="tlink" style="font-size: 14px;">← Andere Adresse verwenden</a>
          </p>
        </div>
      ) : (
        <form method="post" action="/api/auth/login" style="margin-top: 32px;">
          <label class="app-label">
            <span class="app-label-text">E-Mail-Adresse</span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="anwalt@kanzlei-beispiel.de"
              class="app-input"
            />
          </label>
          <button type="submit" class="btn">
            <span>Anmeldelink schicken</span>
            <span class="arrow">→</span>
          </button>
          {error && <p class="app-error">{error}</p>}
        </form>
      )}

      <p style="margin-top: 32px; font-size: 13px; color: var(--muted);">
        <a href="/" class="tlink">← zurück zur Startseite</a>
      </p>
    </div>
  </main>
</AppLayout>
