---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Mandantor übernimmt einen Schritt — den Erstkontakt — präzise und unauffällig. DSGVO-konform, EU-gehostet.',
  noindex = false,
} = Astro.props;
// Site steht hinter Basic-Auth-Schranke — robots immer auf noindex,
// damit auch die 401-Seite nicht indexiert wird (zusätzlich zu robots.txt).
const effectiveNoindex = true;
void noindex;
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {effectiveNoindex && <meta name="robots" content="noindex,nofollow" />}

  <link rel="icon" type="image/svg+xml" href="/icon.svg" />
</head>
<body>
  <slot />
</body>
</html>
