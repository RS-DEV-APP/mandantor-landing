---
import OnboardingLayout from '../../../components/OnboardingLayout.astro';
import { findKanzleiById } from '../../../lib/db';

export const prerender = false;

const session = Astro.locals.session;
const env = Astro.locals.runtime?.env;
if (!session) return Astro.redirect('/app/login', 302);
if (!env?.DB) return new Response('Server misconfigured', { status: 500 });

const kanzlei = await findKanzleiById(env.DB, session.kanzlei_id);
if (!kanzlei) return Astro.redirect('/app/login', 302);
if (kanzlei.onboarding_completed_at) return Astro.redirect('/app/dashboard', 302);

// Heuristik: wenn der Display-Name noch wie auto-generiert aussieht (Email-Prefix mit Punkt)
const looksAutoGenerated =
  /^[a-zA-Z]\.[a-zA-Z]/.test(kanzlei.display_name) && !kanzlei.display_name.includes(' ');
---
<OnboardingLayout
  step={2}
  title="Wie heißt Ihre Kanzlei?"
  subtitle="Dieser Name erscheint Mandant:innen oben im Onboarding-Wizard und in den Bestätigungs-E-Mails."
>
  <form method="post" action="/api/onboarding/kanzlei" class="onb-card">
    {looksAutoGenerated && (
      <p class="onb-hint">
        Aktuell zeigen wir <code>{kanzlei.display_name}</code> — das wirkt automatisch generiert.
        Bitte tragen Sie hier den korrekten Anzeigenamen Ihrer Kanzlei ein.
      </p>
    )}

    <label class="app-label" style="margin-bottom: 0;">
      <span class="app-label-text">Kanzlei-Anzeigename *</span>
      <input
        class="app-input"
        type="text"
        name="display_name"
        required
        maxlength="80"
        value={looksAutoGenerated ? '' : kanzlei.display_name}
        placeholder="z. B. Kanzlei Müller & Schulz"
        autofocus
      />
      <span style="font-size: 12px; color: var(--muted); margin-top: 6px;">
        Idealerweise mit Rechtsform/Bezeichnung — also „Kanzlei Müller & Schulz" oder „Dr. Anna Müller, Rechtsanwältin".
      </span>
    </label>
  </form>

  <div class="onb-cta-row">
    <a href="/app/onboarding" class="btn-link">← Zurück</a>
    <div style="display: flex; gap: 12px; align-items: center;">
      <a href="/app/onboarding/branding" class="btn-link">Überspringen</a>
      <button type="submit" form-id form="kanzlei-form" onclick="document.querySelector('form[action=&quot;/api/onboarding/kanzlei&quot;]').submit()" class="cta-button">
        Speichern & weiter <span class="arrow">→</span>
      </button>
    </div>
  </div>
</OnboardingLayout>

<style>
  .onb-card {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: 32px;
    margin-bottom: 24px;
  }
  .onb-hint {
    background: #fffaf0;
    border: 1px solid #e6d4a3;
    border-left: 4px solid var(--gold);
    padding: 12px 16px;
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.5;
    margin: 0 0 24px;
  }
  .onb-cta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .cta-button {
    padding: 14px 24px;
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--paper);
    background: var(--ink);
    border: 1px solid var(--ink);
    border-radius: 2px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .cta-button:hover { background: #1a2436; }
  .btn-link {
    background: transparent;
    border: 0;
    color: var(--muted);
    font-family: var(--sans);
    font-size: 14px;
    cursor: pointer;
    text-decoration: underline;
    padding: 8px 0;
  }
  .btn-link:hover { color: var(--ink); }
</style>
